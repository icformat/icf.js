@kind icf
@version 1.0
@encoding utf-8
@delimiter comma
@escape backslash

@schema

OCRText:
  [Content]

Configuration:
  [Json]

@data

@record

OCRText:

  <<TEXT
  Invoice No: INV-2026-001
  Vendor: ABC Traders

  @record
  # not a comment
  Total: Rs. 84,500
  TEXT>>

Configuration:

  <<TEXT
  {
    "host": "localhost",
    "port": 5432
  }
  TEXT>>
